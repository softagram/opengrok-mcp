{
  "name": "opengrok-mcp",
  "version": "1.0.0",
  "description": "MCP server that exposes OpenGrok code search as tools for LLM agents",
  "license": "ISC",
  "type": "module",
  "exports": "./dist/index.js",
  "bin": {
    "opengrok-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test --test-reporter=spec tests/*.test.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "opengrok",
    "code-search",
    "model-context-protocol"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "axios": "^1.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.2",
    "typescript": "^5.4.3"
  }
}
